# pnpm configuration for Simple Reader
# node-linker=hoisted keeps a flat node_modules layout (like npm/yarn classic),
# which is the most compatible option for @fluentui/react v8, webpack 5,
# node-polyfill-webpack-plugin and electron-builder.
node-linker=hoisted
# shamefully-hoist=true hoists all deps to the top-level node_modules so
# packages relying on undeclared/peer resolution (common in the fluentui +
# webpack ecosystem) can find their dependencies.
shamefully-hoist=true
